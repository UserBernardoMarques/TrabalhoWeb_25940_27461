@page
@model TrabalhoWeb_25940.Pages.Workshops.ExplorarModel
@{
    ViewData["Title"] = "Explorar Workshops";
}

<div class="container mt-5 mb-5 pb-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary"><i class="bi bi-easel2"></i> Workshops Disponíveis</h1>
        <p class="lead text-muted">Descobre e inscreve-te nos melhores eventos da plataforma Gatherio.</p>
    </div>

    @if (Model.Workshop.Count == 0)
    {
        <div class="alert alert-light text-center py-5 shadow-sm border-0 rounded-4">
            <i class="bi bi-calendar-x display-1 text-secondary mb-3"></i>
            <h3 class="fw-bold">Ainda não há workshops agendados!</h3>
            <p class="text-muted">Fica atento, a nossa equipa está a preparar novos eventos para ti.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model.Workshop)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-effect">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary fs-6">@(item.Categoria?.Nome ?? "Sem Categoria")</span>
                                <small class="text-muted fw-bold"><i class="bi bi-clock"></i> @item.Data.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            <h4 class="card-title fw-bold mb-3">@item.Titulo</h4>
                            <p class="card-text text-muted mb-4">@item.Descricao</p>
                            
                            <div class="mt-auto pt-3 border-top text-center">
                                <a asp-page="/Workshops/Inscrever" asp-route-id="@item.Id" class="btn btn-outline-primary w-100 fw-bold">
                                    <i class="bi bi-person-plus"></i> Inscrever-me
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* Pequeno efeito para os cartões saltarem quando passas o rato */
    .hover-effect {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 12px;
    }
    .hover-effect:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>