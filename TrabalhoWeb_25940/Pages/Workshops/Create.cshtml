@page
@model TrabalhoWeb_25940.Pages.Workshops.CreateModel

@{
    ViewData["Title"] = "Criar Workshop";
}

<div class="container mt-4">
    <h1 class="text-success">Criar Novo Workshop</h1>
    <p class="text-muted">Preencha os dados para agendar um novo evento.</p>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="Workshop.Titulo" class="form-label fw-bold">Título do Workshop</label>
                            <input asp-for="Workshop.Titulo" class="form-control" placeholder="Ex: Aprender C# do zero" />
                            <span asp-validation-for="Workshop.Titulo" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="Workshop.Descricao" class="form-label fw-bold">Descrição</label>
                            <textarea asp-for="Workshop.Descricao" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Workshop.Descricao" class="text-danger"></span>
                        </div>
                        
                        <div class="form-group mb-3">
                            <label asp-for="Workshop.Data" class="form-label fw-bold">Data e Hora</label>
                            <input asp-for="Workshop.Data" class="form-control" />
                            <span asp-validation-for="Workshop.Data" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Workshop.CategoriaId" class="form-label fw-bold">Categoria</label>
                            <select asp-for="Workshop.CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId">
                                <option value="">-- Selecione uma Categoria --</option>
                            </select>
                            <span asp-validation-for="Workshop.CategoriaId" class="text-danger"></span>
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <a asp-page="Index" class="btn btn-outline-secondary">Voltar à Lista</a>
                            <input type="submit" value="Criar Workshop" class="btn btn-success px-4" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}