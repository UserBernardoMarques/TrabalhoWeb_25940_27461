@page
@model TrabalhoWeb_25940.Pages.Workshops.InscreverModel
@{
    ViewData["Title"] = "Confirmar Inscrição";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4 p-4 text-center">
                <i class="bi bi-ticket-perforated display-1 text-primary mb-3"></i>
                <h2 class="fw-bold text-dark">Confirmar Inscrição</h2>
                <hr />
                
                <h5 class="mb-4 text-muted">Estás prestes a inscrever-te no workshop:</h5>
                <h4 class="fw-bold text-primary mb-4">"@Model.Workshop.Titulo"</h4>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> Verifica o teu email. Não encontrámos nenhuma conta registada com esse endereço.
                    </div>
                }

                <form method="post">
                    <input type="hidden" asp-for="Workshop.Id" />
                    
                    <div class="mb-4 text-start">
                        <label class="form-label fw-bold">Para confirmar a inscrição, digita o Email da tua conta:</label>
                        <input asp-for="EmailConfirmacao" class="form-control form-control-lg" type="email" placeholder="O teu email de registo" required />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill">Confirmar a Minha Vaga</button>
                        <a href="/Workshops/Explorar" class="btn btn-light fw-bold rounded-pill">Cancelar e Voltar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>