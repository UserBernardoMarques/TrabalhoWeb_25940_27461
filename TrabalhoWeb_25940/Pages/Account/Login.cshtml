@page
@model TrabalhoWeb_25940.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 rounded-4 p-4">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary"><i class="bi bi-box-arrow-in-right"></i> Entrar</h2>
                    <p class="text-muted">Bem-vindo de volta ao Gatherio!</p>
                </div>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger shadow-sm pb-0">
                        <div asp-validation-summary="All" class="text-danger fw-bold"></div>
                    </div>
                }

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg" type="email" placeholder="nome@exemplo.com" required />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Palavra-passe</label>
                        <input asp-for="Input.Password" class="form-control form-control-lg" type="password" placeholder="A tua palavra-passe" required />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold rounded-pill">Entrar na Conta</button>
                    </div>
                    
                    <div class="text-center mt-4">
                        <span class="text-muted">Ainda não tens conta? <a href="/Account/Registar" class="text-decoration-none fw-bold">Regista-te aqui</a></span>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}