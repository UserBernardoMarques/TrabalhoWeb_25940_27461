@page
@model TrabalhoWeb_25940.Pages.Account.RegistarModel
@{ ViewData["Title"] = "Criar Conta"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form method="post" class="card shadow p-4">
                <h2>Criar Conta</h2>
                <div asp-validation-summary="All" class="text-danger"></div>
                
                <div class="mb-3">
                    <label>Nome</label>
                    <input asp-for="Input.Nome" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Idade</label>
                    <input asp-for="Input.Idade" class="form-control" type="number" />
                </div>
                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Input.Email" class="form-control" type="email" />
                </div>
                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="Input.Password" class="form-control" type="password" />
                </div>
                
                <div class="mb-3">
                    <input asp-for="Input.IsAluno" type="checkbox" /> Sou Aluno<br />
                    <input asp-for="Input.IsFormador" type="checkbox" /> Sou Formador
                </div>
                
                <button type="submit" class="btn btn-primary">Registar</button>
            </form>
        </div>
    </div>
</div>