<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gatherio</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.2/dist/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrabalhoWeb_25940.styles.css" asp-append-version="true" />

    <style>
            body {
                background-color: #f8f9fa;
            }

            .navbar {
                padding: 15px 0;
            }

            /* Animação para o Sino abanar (Com a correção @@ para o Razor) */
            @@keyframes abanar {
                0% {
                    transform: rotate(0);
                }

                15% {
                    transform: rotate(20deg);
                }

                30% {
                    transform: rotate(-20deg);
                }

                45% {
                    transform: rotate(10deg);
                }

                60% {
                    transform: rotate(-10deg);
                }

                75% {
                    transform: rotate(0);
                }

                100% {
                    transform: rotate(0);
                }
            }

            .animacao-sino {
                display: inline-block;
                animation: abanar 1.5s ease-in-out infinite;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary shadow">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-diagram-3"></i> gather.io</h3>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">

                    <ul class="navbar-nav align-items-center">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-4 border-end border-light pe-4">
                                <a class="nav-link text-warning fw-bold fs-6" href="/Workshops/MeusWorkshops">
                                    <i class="bi bi-easel-fill me-1"></i> As Minhas Formações
                                </a>
                            </li>

                            <li class="nav-item me-3">
                                <span class="nav-link text-white fw-bold">
                                    <i class="bi bi-person-circle"></i> Olá, @User.Identity.Name!
                                </span>
                            </li>
                            <li class="nav-item me-3">
                                <a class="nav-link text-danger fw-bold" asp-area="" asp-page="/Account/Logout">
                                    <i class="bi bi-box-arrow-right"></i> Sair
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-white fw-bold" asp-area="" asp-page="/Account/Login">
                                    Entrar
                                </a>
                            </li>
                            <li class="nav-item me-3">
                                <a href="/Account/Registar" class="btn btn-warning text-dark fw-bold rounded-pill px-3">
                                    <i class="bi bi-person-plus-fill"></i> Criar Conta
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link active fw-bold text-warning" asp-area="" asp-page="/Index">
                                    <i class="bi bi-shield-lock-fill"></i> Painel Admin
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div id="caixaSino" class="alert shadow-lg bg-white" style="position: fixed; top: 90px; left: 20px; z-index: 1050; display: none; border: 1px solid #dee2e6; border-left: 5px solid #ffc107; min-width: 320px; border-radius: 8px;">
        <div class="d-flex align-items-center">
            <i class="bi bi-bell-fill fs-2 text-warning me-3 animacao-sino"></i>
            <div>
                <h6 class="mb-1 fw-bold text-dark">Nova Atualização</h6>
                <span id="textoSino" class="text-muted" style="font-size: 0.95rem;"></span>
            </div>
            <button type="button" class="btn-close ms-auto mb-auto mt-1" onclick="document.getElementById('caixaSino').style.display='none'"></button>
        </div>
    </div>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto py-3 shadow-sm">
        <div class="container text-center">
            &copy; 2026 - <i class="bi bi-laptop"></i> Eng. Informática IPT - Desenvolvimento Web
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>